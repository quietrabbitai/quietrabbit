# Quiet Rabbit — Environment Configuration
# Copy to .env and set only what differs from your topology defaults.
# Topology A (single machine, Ollama local): no .env needed.
#
# WARNING: API keys (Mistral, Groq) are NEVER set here.
#   They are stored in QR's encrypted database via the settings UI.
#   Adding API keys to this file would expose them as plaintext.

# -- Topology presets ------------------------------------------------------
# Topology A: nothing — defaults work
# Topology B: OLLAMA_HOST=192.168.x.x
# Topology C: OLLAMA_HOST=192.168.x.x + QR_LOCAL_DATA=... + QR_NETWORK_STORAGE=true

# -- Inference -------------------------------------------------------------

# Ollama host. Default: host.docker.internal (host machine, Topology A)
OLLAMA_HOST=

# Ollama port. Default: 11434
OLLAMA_PORT=

# -- Data ------------------------------------------------------------------

# Local directory mounted as /data/quietrabbit in the container.
# Default: ./quietrabbit-data (beside compose file, Topology A)
QR_LOCAL_DATA=

# -- Environment -----------------------------------------------------------

# production | development
# WARNING: NEVER set development in production.
#   Development mode logs assembled prompts and routing decisions.
QR_ENV=

# true if data root is a network mount (NAS/NFS/SMB).
# Enables rollback journal instead of WAL. Required for correct
# SQLite behaviour on network storage.
QR_NETWORK_STORAGE=

# true to allow HTTP (LAN/localhost). Set false only when adding
# an HTTPS reverse proxy — doing so requires SESSION_COOKIE_SECURE=true.
QR_ALLOW_HTTP=

# -- Tuning ----------------------------------------------------------------
# These rarely need changing. Uncomment and set only if you have a reason.

# QR_STARTUP_INTEGRITY_CHECK=true
# QR_FALLBACK_ON_INTEGRITY_FAIL=true
# QR_LOOP_DETECTION_THRESHOLD=3
# QR_CONTEXT_WARNING_THRESHOLD=0.75
# QR_QUALITY_FLOOR=0.55
# QR_INTERRUPT_THRESHOLD_MINUTES=5
# QR_MAX_CONCURRENT_PATHS=3
# QR_CHECKPOINT_EVERY_N_STEPS=3
